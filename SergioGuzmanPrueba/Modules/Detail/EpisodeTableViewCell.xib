<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB"
          version="3.0"
          toolsVersion="21701"
          targetRuntime="iOS.CocoaTouch"
          propertyAccessControl="none"
          useAutolayout="YES"
          useTraitCollections="YES"
          useSafeAreas="YES"
          colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21678"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>

        <!-- EpisodeTableViewCell -->
        <tableViewCell
            clipsSubviews="YES"
            contentMode="scaleToFill"
            selectionStyle="default"
            indentationWidth="10"
            reuseIdentifier="EpisodeCell"
            id="EPC-00-001"
            customClass="EpisodeTableViewCell"
            customModuleProvider="target">

            <rect key="frame" x="0.0" y="0.0" width="393" height="60"/>
            <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>

            <tableViewCellContentView
                key="contentView"
                opaque="YES"
                clipsSubviews="YES"
                multipleTouchEnabled="YES"
                contentMode="center"
                insetsLayoutMarginsFromSafeArea="NO"
                id="EPC-CV-001">
                <rect key="frame" x="0.0" y="0.0" width="393" height="60"/>
                <autoresizingMask key="autoresizingMask"/>
                <subviews>

                    <!-- Viewed icon: left side -->
                    <imageView
                        opaque="NO"
                        userInteractionEnabled="NO"
                        contentMode="scaleAspectFit"
                        translatesAutoresizingMaskIntoConstraints="NO"
                        id="EPC-ICON-001">
                        <rect key="frame" x="12" y="18" width="24" height="24"/>
                        <color key="tintColor" systemColor="systemGray3Color"/>
                    </imageView>

                    <!-- Episode code label: "S01E01" -->
                    <label
                        opaque="NO"
                        userInteractionEnabled="NO"
                        contentMode="left"
                        horizontalHuggingPriority="252"
                        verticalHuggingPriority="251"
                        text="S01E01"
                        textAlignment="natural"
                        lineBreakMode="middleTruncation"
                        numberOfLines="1"
                        adjustsFontSizeToFit="NO"
                        translatesAutoresizingMaskIntoConstraints="NO"
                        id="EPC-CODE-001">
                        <rect key="frame" x="48" y="10" width="60" height="18"/>
                        <fontDescription key="fontDescription" type="boldSystem" pointSize="14"/>
                        <color key="textColor" systemColor="labelColor"/>
                        <nil key="highlightedColor"/>
                    </label>

                    <!-- Episode name label -->
                    <label
                        opaque="NO"
                        userInteractionEnabled="NO"
                        contentMode="left"
                        horizontalHuggingPriority="251"
                        verticalHuggingPriority="251"
                        text="Episode Name"
                        textAlignment="natural"
                        lineBreakMode="wordWrap"
                        numberOfLines="2"
                        adjustsFontSizeToFit="NO"
                        translatesAutoresizingMaskIntoConstraints="NO"
                        id="EPC-NAME-001">
                        <rect key="frame" x="48" y="30" width="333" height="20"/>
                        <fontDescription key="fontDescription" type="system" pointSize="13"/>
                        <color key="textColor" systemColor="secondaryLabelColor"/>
                        <nil key="highlightedColor"/>
                    </label>

                </subviews>

                <!-- Constraints -->
                <constraints>
                    <!-- Icon: leading -->
                    <constraint firstItem="EPC-ICON-001" firstAttribute="leading"
                                secondItem="EPC-CV-001" secondAttribute="leading"
                                constant="12" id="EPC-C-ICON-L"/>
                    <!-- Icon: center Y -->
                    <constraint firstItem="EPC-ICON-001" firstAttribute="centerY"
                                secondItem="EPC-CV-001" secondAttribute="centerY"
                                id="EPC-C-ICON-CY"/>
                    <!-- Icon: width -->
                    <constraint firstItem="EPC-ICON-001" firstAttribute="width"
                                constant="24" id="EPC-C-ICON-W"/>
                    <!-- Icon: height -->
                    <constraint firstItem="EPC-ICON-001" firstAttribute="height"
                                constant="24" id="EPC-C-ICON-H"/>

                    <!-- Code label: leading = icon trailing + 12 -->
                    <constraint firstItem="EPC-CODE-001" firstAttribute="leading"
                                secondItem="EPC-ICON-001" secondAttribute="trailing"
                                constant="12" id="EPC-C-CODE-L"/>
                    <!-- Code label: top -->
                    <constraint firstItem="EPC-CODE-001" firstAttribute="top"
                                secondItem="EPC-CV-001" secondAttribute="top"
                                constant="10" id="EPC-C-CODE-T"/>
                    <!-- Code label: trailing -->
                    <constraint firstItem="EPC-CV-001" firstAttribute="trailing"
                                secondItem="EPC-CODE-001" secondAttribute="trailing"
                                constant="12" id="EPC-C-CODE-R"/>

                    <!-- Name label: leading = code label leading -->
                    <constraint firstItem="EPC-NAME-001" firstAttribute="leading"
                                secondItem="EPC-CODE-001" secondAttribute="leading"
                                id="EPC-C-NAME-L"/>
                    <!-- Name label: top = code bottom + 4 -->
                    <constraint firstItem="EPC-NAME-001" firstAttribute="top"
                                secondItem="EPC-CODE-001" secondAttribute="bottom"
                                constant="4" id="EPC-C-NAME-T"/>
                    <!-- Name label: trailing -->
                    <constraint firstItem="EPC-CV-001" firstAttribute="trailing"
                                secondItem="EPC-NAME-001" secondAttribute="trailing"
                                constant="12" id="EPC-C-NAME-R"/>
                    <!-- Name label: bottom → closes vertical chain -->
                    <constraint firstItem="EPC-CV-001" firstAttribute="bottom"
                                secondItem="EPC-NAME-001" secondAttribute="bottom"
                                constant="10" relation="greaterThanOrEqual"
                                id="EPC-C-NAME-B"/>
                </constraints>

            </tableViewCellContentView>

            <!-- IBOutlet connections -->
            <connections>
                <outlet property="episodeCodeLabel"     destination="EPC-CODE-001" id="O-EPC-CODE"/>
                <outlet property="episodeNameLabel"     destination="EPC-NAME-001" id="O-EPC-NAME"/>
                <outlet property="viewedIconImageView"  destination="EPC-ICON-001" id="O-EPC-ICON"/>
            </connections>
        </tableViewCell>
    </objects>

    <resources>
        <systemColor name="labelColor">
            <color white="0.0" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
        <systemColor name="secondaryLabelColor">
            <color red="0.235" green="0.235" blue="0.263" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
        <systemColor name="systemGray3Color">
            <color red="0.678" green="0.682" blue="0.702" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
    </resources>
</document>
