<?xml version="1.0" encoding="UTF-8"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.Storyboard.XIB"
          version="3.0"
          toolsVersion="21701"
          targetRuntime="iOS.CocoaTouch"
          propertyAccessControl="none"
          useAutolayout="YES"
          useTraitCollections="YES"
          useSafeAreas="YES"
          colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="21678"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="System colors in document resources" minToolsVersion="11.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <scenes>
        <!-- Map View Controller -->
        <scene sceneID="MAP-SC-001">
            <objects>
                <viewController
                    id="MAP-VC-001"
                    customClass="MapViewController"
                    customModuleProvider="target"
                    storyboardIdentifier="MapViewController"
                    sceneMemberID="viewController">

                    <view key="view"
                          contentMode="scaleToFill"
                          id="MAP-V-001">
                        <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                        <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
                        <color key="backgroundColor" systemColor="systemBackgroundColor"/>

                        <subviews>
                            <!-- MKMapView — ocupa toda la pantalla -->
                            <mapView
                                clipsSubviews="YES"
                                multipleTouchEnabled="YES"
                                contentMode="scaleToFill"
                                mapType="standard"
                                showsUserLocation="NO"
                                translatesAutoresizingMaskIntoConstraints="NO"
                                id="MAP-MK-001">
                                <rect key="frame" x="0.0" y="0.0" width="393" height="852"/>
                            </mapView>
                        </subviews>

                        <!-- MKMapView fills safe area -->
                        <constraints>
                            <constraint firstItem="MAP-MK-001" firstAttribute="leading"
                                        secondItem="MAP-V-001" secondAttribute="leading"
                                        id="MAP-MK-L"/>
                            <constraint firstItem="MAP-MK-001" firstAttribute="trailing"
                                        secondItem="MAP-V-001" secondAttribute="trailing"
                                        id="MAP-MK-R"/>
                            <constraint firstItem="MAP-MK-001" firstAttribute="top"
                                        secondItem="MAP-V-001" secondAttribute="top"
                                        id="MAP-MK-T"/>
                            <constraint firstItem="MAP-MK-001" firstAttribute="bottom"
                                        secondItem="MAP-V-001" secondAttribute="bottom"
                                        id="MAP-MK-B"/>
                        </constraints>

                        <viewLayoutGuide key="safeArea" id="MAP-SA-001"/>
                    </view>

                    <!-- IBOutlet connections -->
                    <connections>
                        <outlet property="mapView" destination="MAP-MK-001" id="O-MAP-MV"/>
                    </connections>

                </viewController>

                <placeholder placeholderIdentifier="IBFirstResponder"
                             id="MAP-FR-001"
                             userLabel="First Responder"
                             sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="53" y="375"/>
        </scene>
    </scenes>

    <resources>
        <systemColor name="systemBackgroundColor">
            <color white="1" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
        </systemColor>
    </resources>
</document>
